{
  "name": "gtm-kit",
  "version": "2.16.0",
  "description": "Development files for the GTM Kit",
  "author": "GTM Kit",
  "keywords": [
    "woocommerce",
    "wordpress",
    "google tag manager"
  ],
  "homepage": "https://github.com/tlamedia/gtm-kit",
  "plugin": {
    "textdomain": "gtm-kit"
  },
  "dependencies": {
    "@wordpress/api-fetch": "^7.33.1",
    "@wordpress/components": "^30.6.4",
    "@wordpress/element": "^6.33.0",
    "@wordpress/hooks": "^4.33.1",
    "@wordpress/i18n": "^6.6.1",
    "@wordpress/icons": "^11.0.1",
    "@wordpress/plugins": "^7.33.4",
    "@wordpress/url": "^4.33.1",
    "classnames": "^2.5.1",
    "dompurify": "^3.3.1",
    "lodash": "^4.17.23",
    "lodash-es": "^4.17.21",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.3",
    "react-transition-group": "^4.4.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.19.39",
    "@wordpress/e2e-test-utils-playwright": "^1.45.0",
    "@wordpress/env": "^10.39.0",
    "@wordpress/scripts": "^30.26.2",
    "autoprefixer": "^10.4.23",
    "cssnano": "^7.1.2",
    "del-cli": "^7.0.0",
    "identity-obj-proxy": "^3.0.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^25.0.1",
    "mkdirp": "^3.0.1",
    "ncp": "^2.0.0",
    "node-wp-i18n": "^1.2.8",
    "postcss-cli": "^11.0.1",
    "sass": "^1.97.2",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "uglify-js": "^3.19.3",
    "vitest": "^2.1.9"
  },
  "scripts": {
    "build": "wp-scripts build src/js/frontend/woocommerce-blocks.js --output-path=assets/frontend",
    "build:introductions": "wp-scripts build src/js/admin/introductions/introductions.js --output-path=assets/admin",
    "build:settings": "wp-scripts build src/js/admin/settings.js src/js/admin/wizard.js --output-path=assets/admin",
    "build:assets": "npm run clean:assets && npm run build:js && npm run build:introductions && npm run build:settings && npm run copy:images && npm run check:consent-gating-size && npm run check:engagement-events-size",
    "build:js": "npm run uglify:woocommerce && npm run uglify:woocommerce-checkout && npm run uglify:edd && npm run uglify:edd-checkout && npm run uglify:cf7 && npm run uglify:consent-gating && npm run uglify:engagement-events",
    "check:consent-gating-size": "node ./bin/check-consent-gating-size.js",
    "check:engagement-events-size": "node ./bin/check-engagement-events-size.js",
    "clean:assets": "del assets",
    "i18n:pot": "wp i18n make-pot ./ languages/gtm-kit.pot",
    "change-version": "./bin/change-version.sh $npm_package_version",
    "zip-package": "./bin/zip-package.sh",
    "uglify:woocommerce": "mkdirp assets/integration && uglifyjs src/js/woocommerce.js --compress --mangle --output assets/integration/woocommerce.js",
    "uglify:woocommerce-checkout": "mkdirp assets/integration && uglifyjs src/js/woocommerce-checkout.js --compress --mangle --output assets/integration/woocommerce-checkout.js",
    "uglify:edd": "mkdirp assets/integration && uglifyjs src/js/edd.js --compress --mangle --output assets/integration/edd.js",
    "uglify:edd-checkout": "mkdirp assets/integration && uglifyjs src/js/edd-checkout.js --compress --mangle --output assets/integration/edd-checkout.js",
    "uglify:cf7": "mkdirp assets/integration && uglifyjs src/js/contact-form-7.js --compress --mangle --output assets/integration/contact-form-7.js",
    "uglify:consent-gating": "mkdirp assets/frontend && uglifyjs src/js/consent-gating.js --compress --mangle --output assets/frontend/consent-gating.js",
    "uglify:engagement-events": "mkdirp assets/frontend && uglifyjs src/js/engagement-events.js --compress --mangle --output assets/frontend/engagement-events.js",
    "copy:images": "node ./bin/copy-images.js",
    "format": "wp-scripts format ./src/js",
    "lint:css": "wp-scripts lint-style",
    "lint:js": "wp-scripts lint-js ./src/js",
    "lint:js-fix": "wp-scripts lint-js ./src/js --fix",
    "watch": "wp-scripts start src/js/frontend/woocommerce-blocks.js --output-path=assets/frontend",
    "watch:settings": "wp-scripts start src/js/admin/settings.js src/js/admin/wizard.js --output-path=assets/admin",
    "watch:tailwind": "npx tailwindcss -i ./src/scss/tailwind.scss -o ./src/scss/_tailwind-compiled.scss --watch",
    "audit:prod": "npm audit --omit=dev",
    "lint:pkg-json": "wp-scripts lint-pkg-json",
    "packages-update": "wp-scripts packages-update",
    "check-engines": "wp-scripts check-engines",
    "test": "vitest run",
    "test:settings": "wp-scripts test-unit-js --config jest.config.js",
    "test:e2e:blocks": "playwright test --config tests/e2e/blocks/playwright.config.ts",
    "test:e2e:blocks:env:start": "wp-env start && bash tests/e2e/blocks/fixtures/seed-block-store.sh",
    "test:e2e:blocks:env:stop": "wp-env stop",
    "test:e2e:blocks:env:seed": "bash tests/e2e/blocks/fixtures/seed-block-store.sh",
    "test:e2e:blocks:full": "npm run test:e2e:blocks:env:start && npm run test:e2e:blocks && npm run test:e2e:blocks:env:stop",
    "test:e2e:blocks:install": "playwright install chromium"
  }
}
